# Copia este archivo a .env (ya está en .gitignore, nunca se sube al repo).
# Valores en Supabase: Project Settings → API.

PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo servidor — usadas por las rutas API con `prerender = false` (crear sesión de
# pago, webhook de Stripe). NUNCA se suben al repo (.env está en .gitignore); en
# producción se configuran en Netlify → Site settings → Environment variables.

# Secret key de Supabase (Project Settings → API → Secret keys → default, empieza
# por sb_secret_...): salta RLS, solo la usa el webhook para crear pedidos ya pagados.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Stripe (modo test primero: dashboard.stripe.com/test/apikeys).
STRIPE_SECRET_KEY=sk_test_...
# La da `stripe listen` en local, o el dashboard al crear el endpoint del webhook en producción.
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (resend.com/api-keys) — email de confirmación con marca NINUMÁ.
RESEND_API_KEY=re_...
RESEND_FROM=NINUMÁ <pedidos@ninuma.es>

# Dominio público (sin barra final) — para las imágenes del email. Cambiar a
# https://www.ninuma.es en el cutover final, no antes de que el DNS apunte ahí.
SITE_URL=https://ninuma.netlify.app
