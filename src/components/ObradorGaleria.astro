---
import { Image } from "astro:assets";
import espacio1 from "../assets/img/espacio/espacio-1.jpg";
import espacio2 from "../assets/img/espacio/espacio-2.jpg";
import espacio3 from "../assets/img/espacio/espacio-3.jpg";
import espacio4 from "../assets/img/espacio/espacio-4.jpg";
import espacio5 from "../assets/img/espacio/espacio-5.jpg";
import espacio6 from "../assets/img/espacio/espacio-6.jpg";

const cells = [
  { key: "obrador", src: espacio1, label: "Obrador", alt: "El obrador de NINUMÁ en Palma de Mallorca", span: "md:col-span-5 md:row-span-2", aspect: "aspect-[4/5] md:aspect-[10/13]" },
  { key: "proceso", src: espacio2, label: "Proceso", alt: "Proceso de elaboración artesanal en el obrador de NINUMÁ", span: "md:col-span-4", aspect: "aspect-square md:aspect-[4/3]" },
  { key: "detalle", src: espacio3, label: "Detalle", alt: "Detalle del espacio de NINUMÁ", span: "md:col-span-3", aspect: "aspect-square md:aspect-[5/6]" },
  { key: "vitrina", src: espacio4, label: "Vitrina", alt: "Vitrina de producto del obrador NINUMÁ", span: "col-span-2 md:col-span-7", aspect: "aspect-[16/9] md:aspect-[20/11]" },
  { key: "taller", src: espacio5, label: "Taller", alt: "Zona de taller y producción de NINUMÁ", span: "md:col-span-3", aspect: "aspect-square" },
  { key: "luz", src: espacio6, label: "Luz", alt: "Iluminación característica del obrador NINUMÁ", span: "md:col-span-2", aspect: "aspect-[2/3] md:aspect-[2/3]" },
];
---

<section id="espacio" class="border-b border-white/10 px-6 py-24 md:px-12 md:py-36">
  <div class="mx-auto max-w-[1440px]">
    <div class="gs-reveal mb-12 flex flex-wrap items-end justify-between gap-6 md:mb-16">
      <div>
        <span class="text-xs tracking-[0.14em] text-pink uppercase" data-i18n="obrador.galeriaEyebrow">El espacio</span>
        <h2 class="mt-4 max-w-xl h2-fluid" data-i18n="obrador.galeriaHeading">
          Un taller que<br />también es escena.
        </h2>
      </div>
      <p class="max-w-[36ch] text-sm text-white/60" data-i18n="obrador.galeriaIntro">
        Diseñado para el proceso, no para la foto. La vitrina es la carta y la carta es lo que hay ese día.
      </p>
    </div>

    <div class="gs-reveal grid grid-cols-2 gap-2 md:grid-cols-12 md:gap-3" role="list" aria-label="Galería del obrador NINUMÁ">
      {cells.map((c) => (
        <div class={`group relative overflow-hidden bg-charcoal-2 ${c.span} ${c.aspect}`} role="listitem">
          <Image
            src={c.src}
            alt={c.alt}
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            data-i18n-alt={`obrador.galeriaAlt_${c.key}`}
          />
          <span class="absolute bottom-3 left-3 text-[0.58rem] tracking-[0.15em] text-white/60 uppercase" data-i18n={`obrador.galeriaLabel_${c.key}`}>{c.label}</span>
        </div>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap items-start justify-between gap-10 border-t border-white/10 pt-10">
      <div class="flex flex-col gap-2">
        <span class="text-[0.6rem] tracking-[0.22em] text-white/50 uppercase" data-i18n="obrador.datoDireccionLabel">Dirección</span>
        <address class="text-sm text-white/70 not-italic">
          Carrer de Guillem Massot, 48<br />07003 Palma de Mallorca
        </address>
      </div>
      <div class="flex flex-col gap-2">
        <span class="text-[0.6rem] tracking-[0.22em] text-white/50 uppercase" data-i18n="obrador.datoHorarioLabel">Horario</span>
        <p class="text-sm text-white/70" data-i18n="obrador.datoHorarioValue">
          Lun–Jue 10:00–13:30<br />
          Vie 10:30–13:30 · Sáb 10:00–13:30<br />
          Dom cerrado
        </p>
      </div>
      <div class="flex flex-col gap-2">
        <span class="text-[0.6rem] tracking-[0.22em] text-white/50 uppercase" data-i18n="obrador.datoVisitasLabel">Visitas</span>
        <p class="text-sm text-white/70" data-i18n="obrador.datoVisitasValue">Sin cita, bienvenidas.<br />Encargos, siempre previo contacto.</p>
      </div>
      <div class="flex items-start">
        <a
          href="https://maps.app.goo.gl/SqVpRzihGBG3brtX8"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs tracking-[0.14em] text-pink uppercase underline decoration-pink/30 underline-offset-4 hover:decoration-pink"
          data-i18n="obrador.comoLlegar"
        >
          Cómo llegar →
        </a>
      </div>
    </div>
  </div>
</section>
