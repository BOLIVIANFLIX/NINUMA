<section class="gs-reveal border-t border-white/10 bg-charcoal px-6 py-24 text-center md:px-12 md:py-40" aria-labelledby="espera-heading">
  <nav aria-label="Ruta de navegación" data-i18n-aria-label="ediciones.breadcrumbAria" class="mb-12 flex items-center justify-center gap-2 text-xs tracking-wide text-white/50 uppercase">
    <a href="/" data-i18n="ediciones.breadcrumbInicio" class="hover:text-pink">Inicio</a>
    <span aria-hidden="true">/</span>
    <strong aria-current="page" data-i18n="ediciones.breadcrumbCurrent" class="text-white/80">Ediciones Especiales</strong>
  </nav>

  <div class="mx-auto flex max-w-2xl flex-col items-center gap-8">
