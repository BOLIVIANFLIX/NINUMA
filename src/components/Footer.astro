---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 px-6 py-16 md:px-12">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-10 md:flex-row md:justify-between">
    <div class="max-w-[36ch]">
      <span class="font-display text-xl">NINUMÁ</span>
      <p class="mt-2 font-display text-sm italic text-pink" data-i18n="hero.subtitle">Alquimia Cultural</p>
      <p class="mt-4 text-sm text-white/50" data-i18n="footer.description">
        Atelier de pastelería conceptual y cafetería de especialidad. Carrer de Guillem Massot, 48.
      </p>
      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-sm text-pink">
        <a href="https://www.instagram.com/ninuma_concept/" target="_blank" rel="noopener noreferrer" class="hover:underline">Instagram</a>
        <a href="https://www.tiktok.com/@ninuma_concept" target="_blank" rel="noopener noreferrer" class="hover:underline">TikTok</a>
        <a href="https://www.youtube.com/@ninuma_concept" target="_blank" rel="noopener noreferrer" class="hover:underline">YouTube</a>
      </div>
    </div>

    <nav aria-label="Navegación del pie de página" data-i18n-aria-label="footer.navAria">
      <h3 class="text-xs tracking-[0.14em] text-white/50 uppercase" data-i18n="footer.navHeading">Navegar</h3>
      <ul class="mt-4 flex flex-col gap-2 text-sm text-white/70">
        <li><a href="/obrador/" data-i18n="header.navObrador" class="hover:text-pink">Obrador</a></li>
        <li><a href="/creaciones/" data-i18n="header.navCreaciones" class="hover:text-pink">Creaciones</a></li>
        <li><a href="/ediciones-especiales/" data-i18n="header.navEdiciones" class="hover:text-pink">Ediciones</a></li>
        <li><a href="/presencia/" data-i18n="header.navB2b" class="hover:text-pink">B2B</a></li>
        <li><a href="/contacto/" data-i18n="footer.navContacto" class="hover:text-pink">Contacto</a></li>
        <li><a href="/faq/" data-i18n="footer.navFaq" class="hover:text-pink">Preguntas frecuentes</a></li>
      </ul>
    </nav>

    <div>
      <h3 class="text-xs tracking-[0.14em] text-white/50 uppercase" data-i18n="footer.obradorHeading">El Obrador</h3>
      <address class="mt-4 flex flex-col gap-1 text-sm not-italic text-white/70">
        <span>Carrer de Guillem Massot, 48</span>
        <span>07003 Palma de Mallorca</span>
        <a href="tel:+34666138465" class="hover:text-pink">+34 666 13 84 65</a>
        <a href="mailto:ariadna@ninuma.es" class="hover:text-pink">ariadna@ninuma.es</a>
      </address>
    </div>
  </div>

  <div class="mx-auto mt-12 flex max-w-[1440px] flex-col gap-4 border-t border-white/10 pt-6 text-xs text-white/60 md:flex-row md:items-center md:justify-between">
    <p>© {year} NINUMÁ · Ariadna Salvador</p>
    <nav aria-label="Páginas legales" data-i18n-aria-label="footer.legalNavAria" class="flex gap-4 md:mr-20">
      <a href="/aviso-legal/" data-i18n="footer.legalAviso" class="hover:text-pink">Aviso legal</a>
      <a href="/privacidad/" data-i18n="footer.legalPrivacidad" class="hover:text-pink">Privacidad</a>
      <a href="/cookies/" data-i18n="footer.legalCookies" class="hover:text-pink">Cookies</a>
    </nav>
  </div>
</footer>
