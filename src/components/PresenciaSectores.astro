---
import { SECTORES_PRESENCIA as sectores } from "../lib/presenciaSectores";
---

<section id="sectores" class="border-b border-white/10 px-6 py-24 md:px-12 md:py-36">
  <div class="mx-auto max-w-[1440px]">
    <div class="gs-reveal mb-12 md:mb-16">
      <span class="text-xs tracking-[0.14em] text-pink uppercase" data-i18n="presencia.sectoresEyebrow">Con quién trabajamos</span>
      <h2 class="mt-4 max-w-xl h2-fluid" data-i18n="presencia.sectoresHeading">
        Espacios que<br />elevan el detalle.
      </h2>
    </div>

    <div
      class="gs-stagger grid grid-cols-1 gap-px overflow-hidden border border-white/10 bg-white/10 md:grid-cols-2"
      role="list"
      aria-label="Sectores de colaboración"
    >
      {sectores.map((s) => (
        <article class="gs-item group relative flex flex-col gap-5 bg-black p-8 transition-colors hover:bg-charcoal md:p-12" role="listitem">
          <span class="pointer-events-none absolute top-6 right-8 font-display text-7xl text-white/[0.03] select-none" aria-hidden="true">
            {s.n}
          </span>
          <h3 class="font-display text-2xl leading-tight md:text-3xl" data-i18n={`presencia.sector${s.n}Title`}>{s.title}</h3>
          <p class="max-w-[44ch] text-sm text-white/70" data-i18n={`presencia.sector${s.n}Text`}>{s.text}</p>
          <ul class="mt-2 flex flex-col gap-1" aria-label={`Servicios para ${s.title}`}>
            {s.items.map((it, i) => (
              <li
                class="text-[0.65rem] tracking-[0.1em] text-white/60 uppercase before:mr-1.5 before:text-pink before:content-['—']"
                data-i18n={`presencia.sector${s.n}Item${i + 1}`}
              >
                {it}
              </li>
            ))}
          </ul>
          <a
            href={`/presencia/${s.slug}/`}
            class="mt-auto inline-flex w-fit items-center gap-2 text-[0.65rem] tracking-[0.14em] text-pink uppercase"
            data-i18n="presencia.verDetalle"
            aria-label={`Ver detalle de servicios para ${s.title}`}
          >
            Ver detalle →
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
