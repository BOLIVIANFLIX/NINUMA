---
import type { EdicionActiva } from "../lib/edition";

interface Props {
  edition: EdicionActiva;
}
const { edition: EDITION } = Astro.props;
---

<section id="comprar" class="gs-reveal border-t border-white/10 bg-black px-6 py-24 md:px-12 md:py-36" aria-labelledby="comprar-heading">
  <div class="mx-auto grid max-w-[1440px] gap-12 md:grid-cols-2 md:gap-20">
    <div class="flex flex-col gap-6">
      <div>
        <span class="text-xs tracking-[0.14em] text-pink uppercase" data-i18n="ediciones.comprarEyebrow">Compra tu caja</span>
        <h2 id="comprar-heading" class="mt-4 h2-fluid" data-i18n="ediciones.comprarHeading">Asegura<br />tu pieza.</h2>
      </div>
      <p class="text-sm leading-relaxed text-white/60" data-i18n="ediciones.comprarIntro">
        Elige el tamaño de caja, añádela al carrito y paga online. Las unidades se reservan por orden de compra.
      </p>
      <div class="border-l-2 border-pink bg-charcoal p-5">
        <p class="text-xs leading-relaxed text-white/60" data-i18n="ediciones.reservaNota">
          <strong class="font-medium text-pink">Sin envíos.</strong> La recogida es únicamente en el obrador. Guillem Massot, 48 · Palma de Mallorca.
        </p>
      </div>
    </div>

    <div>
      <div id="edicion-selector" data-edicion-slug={EDITION.slug} data-edicion-nombre={EDITION.nombre} class="flex flex-col gap-5">
        <div class="flex flex-col gap-1.5">
          <label class="text-xs tracking-wide text-white/60" for="e-caja" data-i18n="ediciones.labelUnidades">Tamaño de caja *</label>
          <select id="e-caja" class="border-b border-white/20 bg-transparent py-2 text-sm outline-none focus:border-pink">
            {
              EDITION.cajas.map((caja) => (
                <option value={caja.id} data-precio={caja.precio} data-label={caja.label}>
                  {caja.label} — {caja.precio.toFixed(2)} €
                </option>
              ))
            }
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label class="text-xs tracking-wide text-white/60" for="e-unidades" data-i18n="ediciones.labelCantidadCajas">Cuántas cajas *</label>
          <select id="e-unidades" class="w-24 border-b border-white/20 bg-transparent py-2 text-sm outline-none focus:border-pink">
            {Array.from({ length: 10 }, (_, i) => i + 1).map((n) => <option value={n}>{n}</option>)}
          </select>
        </div>

        <button
          type="button"
          id="btn-anadir"
          data-i18n="ediciones.btnAnadir"
          class="mt-2 w-fit rounded-full border border-pink px-6 py-3 text-xs tracking-[0.1em] text-pink uppercase transition-colors hover:bg-pink hover:text-black"
        >
          Añadir al carrito
        </button>
      </div>

      <div id="edicion-carrito" class="mt-10 hidden flex-col gap-4 border-t border-white/10 pt-8">
        <ul id="edicion-carrito-list" class="flex flex-col gap-3"></ul>
        <div class="flex items-center justify-between text-lg">
          <span class="text-white/60" data-i18n="tienda.total">Total</span>
          <span id="edicion-carrito-total" class="font-display text-2xl"></span>
        </div>
        <p id="edicion-minimo-aviso" class="hidden text-xs text-pink-deep" role="alert" data-i18n="tienda.minimoAviso">
          El pedido mínimo para pagar online es de 20 €. Añade alguna caja más para poder pagar.
        </p>
        <button
          type="button"
          id="btn-comprar"
          data-i18n="ediciones.btnComprarAhora"
          class="w-fit rounded-full border border-pink px-6 py-3 text-xs tracking-[0.1em] text-pink uppercase transition-colors hover:bg-pink hover:text-black disabled:cursor-not-allowed disabled:opacity-40"
        >
          Comprar ahora →
        </button>
        <p id="edicion-comprar-error" class="hidden text-xs text-pink-deep" role="alert" aria-live="assertive"></p>
      </div>

      <div id="reserva-cerrada" class="hidden py-8" tabindex="-1" aria-live="polite">
        <h3 class="font-display text-xl text-pink" data-i18n="ediciones.cerradaHeading">Encargos cerrados.</h3>
        <p class="mt-2 text-sm text-white/60" data-i18n="ediciones.cerradaTextCompra">
          El período de compra para esta edición ha finalizado. Escríbenos a <a href="mailto:ariadna@ninuma.es" class="text-pink underline">ariadna@ninuma.es</a> si quieres que te avisemos de la próxima.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  import { addToCart, getCart, updateCartQuantity, removeFromCart, type CartEdicionItem } from "../lib/cartEdicion";
  import { getSessionProfile } from "../lib/auth";
  import { t, getCurrentLang } from "../lib/i18n";

  const MINIMO_CENTS = 2000;

  const selectorWrap = document.getElementById("edicion-selector");
  const edicionSlug = selectorWrap?.dataset.edicionSlug ?? "";
  const edicionNombre = selectorWrap?.dataset.edicionNombre ?? "";
  const cajaSelect = document.getElementById("e-caja") as HTMLSelectElement | null;
  const unidadesSelect = document.getElementById("e-unidades") as HTMLSelectElement | null;
  const btnAnadir = document.getElementById("btn-anadir") as HTMLButtonElement | null;
  const carritoWrap = document.getElementById("edicion-carrito");
  const listEl = document.getElementById("edicion-carrito-list");
  const totalEl = document.getElementById("edicion-carrito-total");
  const minimoAvisoEl = document.getElementById("edicion-minimo-aviso");
  const btnComprar = document.getElementById("btn-comprar") as HTMLButtonElement | null;
  const comprarErrorEl = document.getElementById("edicion-comprar-error");
  const cerradaEl = document.getElementById("reserva-cerrada");

  const eur = new Intl.NumberFormat(getCurrentLang(), { style: "currency", currency: "EUR" });

  function cerrarCompra() {
    selectorWrap?.classList.add("hidden");
    carritoWrap?.classList.add("hidden");
    carritoWrap?.classList.remove("flex");
    cerradaEl?.classList.remove("hidden");
  }

  // El countdown de EdicionHeroActiva puede correr (y expirar) antes de que este
  // script registre el listener, así que también comprobamos el flag directamente.
  if (document.documentElement.dataset.edicionCerrada === "true") {
    cerrarCompra();
  } else {
    document.addEventListener("ninuma:edicion-cerrada", cerrarCompra);
  }

  function renderCarrito() {
    const items = getCart().filter((i) => i.edicionSlug === edicionSlug);
    if (!listEl || !totalEl || !btnComprar) return;

    const hayItems = items.length > 0;
    carritoWrap?.classList.toggle("hidden", !hayItems);
    carritoWrap?.classList.toggle("flex", hayItems);
    if (!hayItems) return;

    listEl.innerHTML = "";
    for (const item of items) {
      const li = document.createElement("li");
      li.className = "flex flex-wrap items-center justify-between gap-4 border border-white/10 px-5 py-3 text-sm";

      const nombre = document.createElement("span");
      nombre.className = "text-white/80";
      nombre.textContent = item.nombre;

      const controls = document.createElement("div");
      controls.className = "flex items-center gap-4";

      const cantidadInput = document.createElement("input");
      cantidadInput.type = "number";
      cantidadInput.min = "1";
      cantidadInput.max = "10";
      cantidadInput.value = String(item.unidades);
      cantidadInput.className = "w-16 border border-white/15 bg-black px-2 py-1 text-sm text-white outline-none focus:border-pink";
      cantidadInput.addEventListener("change", () => {
        const nuevo = Math.max(1, Math.min(10, Number(cantidadInput.value) || 1));
        updateCartQuantity(item.edicionSlug, item.cajaId, nuevo);
        renderCarrito();
      });

      const precio = document.createElement("span");
      precio.className = "w-28 text-right text-white/60";
      precio.textContent = eur.format((item.precioUnitarioCents * item.unidades) / 100);

      const quitarBtn = document.createElement("button");
      quitarBtn.type = "button";
      quitarBtn.className = "text-xs tracking-[0.1em] text-white/50 uppercase hover:text-pink";
      quitarBtn.textContent = t("tienda.quitar", "Quitar");
      quitarBtn.addEventListener("click", () => {
        removeFromCart(item.edicionSlug, item.cajaId);
        renderCarrito();
      });

      controls.append(cantidadInput, precio, quitarBtn);
      li.append(nombre, controls);
      listEl.appendChild(li);
    }

    const totalCents = items.reduce((sum, i) => sum + i.precioUnitarioCents * i.unidades, 0);
    totalEl.textContent = eur.format(totalCents / 100);

    const cumpleMinimo = totalCents >= MINIMO_CENTS;
    minimoAvisoEl?.classList.toggle("hidden", cumpleMinimo);
    btnComprar.disabled = !cumpleMinimo;
  }

  btnAnadir?.addEventListener("click", () => {
    if (!cajaSelect || !unidadesSelect || !edicionSlug) return;
    const opt = cajaSelect.selectedOptions[0];
    const precio = Number(opt?.dataset.precio ?? 0);
    if (!opt || !precio) return;

    addToCart({
      edicionSlug,
      cajaId: cajaSelect.value,
      nombre: `${edicionNombre} — ${opt.dataset.label ?? opt.value}`,
      precioUnitarioCents: Math.round(precio * 100),
      unidades: Number(unidadesSelect.value),
    });

    const original = btnAnadir.textContent;
    btnAnadir.textContent = t("tienda.anadido", "Añadido ✓");
    setTimeout(() => {
      btnAnadir.textContent = original;
    }, 1200);

    renderCarrito();
  });

  btnComprar?.addEventListener("click", async () => {
    if (!btnComprar) return;
    const items = getCart().filter((i) => i.edicionSlug === edicionSlug);
    if (items.length === 0) return;

    btnComprar.disabled = true;
    btnComprar.textContent = t("tienda.redirigiendo", "Redirigiendo a pago…");
    comprarErrorEl?.classList.add("hidden");

    try {
      const profile = await getSessionProfile().catch(() => null);
      const lineas = items.map((i: CartEdicionItem) => ({
        tipo: "edicion",
        edicionSlug: i.edicionSlug,
        cajaId: i.cajaId,
        unidades: i.unidades,
      }));

      const res = await fetch("/api/crear-sesion-pago", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ lineas, userId: profile?.id ?? null, origen: "edicion" }),
      });
      const data = await res.json();
      if (!res.ok || !data.url) throw new Error(data.error || "No se pudo iniciar el pago");
      window.location.href = data.url;
    } catch (err) {
      btnComprar.disabled = false;
      btnComprar.textContent = t("ediciones.btnComprarAhora", "Comprar ahora →");
      if (comprarErrorEl) {
        comprarErrorEl.textContent =
          err instanceof Error && err.message ? err.message : t("tienda.pagarError", "No se ha podido iniciar el pago. Inténtalo de nuevo.");
        comprarErrorEl.classList.remove("hidden");
      }
    }
  });

  renderCarrito();
</script>
