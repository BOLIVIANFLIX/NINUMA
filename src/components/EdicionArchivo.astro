---
import { Image } from "astro:assets";
import { getArchivedEditions } from "../lib/edition";

const ARCHIVO_EDICIONES = await getArchivedEditions();
---

<section class="gs-reveal border-t border-white/10 bg-black px-6 py-24 md:px-12 md:py-36" aria-labelledby="archivo-heading">
  <div class="mx-auto max-w-[1440px]">
    <div class="mb-16">
      <span class="text-xs tracking-[0.14em] text-pink uppercase" data-i18n="ediciones.archivoEyebrow">Archivo</span>
      <h2 id="archivo-heading" class="mt-4 h2-fluid" data-i18n="ediciones.archivoHeading">Lo que ya<br />no existe.</h2>
      <p class="mt-6 max-w-[52ch] text-sm leading-relaxed text-white/60" data-i18n="ediciones.archivoIntro">
        Cada edición, una vez cerrada, pasa al archivo. Son piezas que existieron, que se agotaron y que no volverán a hacerse.
      </p>
    </div>

    <div class="gs-stagger grid grid-cols-1 gap-8 sm:grid-cols-2 md:grid-cols-3" role="list" aria-label="Archivo de ediciones especiales" data-i18n-aria-label="ediciones.archivoListaAria">
      {ARCHIVO_EDICIONES.map((e) => (
        <a href={`/ediciones-especiales/${e.slug}/`} role="listitem" class="gs-item group flex flex-col gap-3 border-b border-white/10 pb-5" aria-label={`${e.nombre} — ver ficha completa`}>
          <div class="relative aspect-[3/4] overflow-hidden bg-charcoal-2">
            {e.imagen ? (
              <Image src={e.imagen} alt={e.alt} loading="lazy" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
            ) : (
              <span class="flex h-full w-full items-center justify-center font-display text-6xl font-light text-white/10">?</span>
            )}
          </div>
          <span class="text-[0.6rem] tracking-[0.18em] text-white/50 uppercase">{e.anio}</span>
          <h3 class="font-display text-2xl leading-tight group-hover:text-pink">{e.nombre}</h3>
          <p class="text-xs leading-relaxed text-white/50" data-i18n={e.metaKey}>{e.meta}</p>
          <span class="text-[0.6rem] tracking-[0.2em] text-white/50 uppercase" data-i18n="ediciones.estadoAgotada">Edición agotada</span>
        </a>
      ))}
    </div>

    <div class="mt-16 border-t border-white/10 pt-8">
      <p class="text-sm text-white/50" data-i18n="ediciones.archivoFooter">
        El portfolio completo de piezas —incluyendo ediciones especiales pasadas— está disponible en <a href="/creaciones/" class="text-pink">Creaciones →</a>
      </p>
    </div>
  </div>
</section>
