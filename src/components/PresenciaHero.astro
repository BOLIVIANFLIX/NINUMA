<section class="relative overflow-hidden border-b border-white/10 bg-charcoal px-6 pt-20 pb-16 md:px-12 md:pt-40 md:pb-24">
  <nav aria-label="Ruta de navegación" class="flex items-center gap-2 text-xs tracking-[0.1em] text-white/50 uppercase">
    <a href="/" class="hover:text-pink" data-i18n="presencia.breadcrumbInicio">Inicio</a>
    <span aria-hidden="true">/</span>
    <strong aria-current="page" class="text-white/80" data-i18n="presencia.breadcrumbCurrent">Presencia</strong>
  </nav>

  <span class="mt-6 block text-xs tracking-[0.14em] text-pink uppercase" data-i18n="presencia.heroEyebrow">Para espacios con identidad</span>

