---
import { Image } from "astro:assets";
import piezaDestacada from "../assets/img/pieza-destacada.jpg";
---

<section id="creaciones" class="gs-reveal border-t border-white/10 bg-charcoal">
  <div class="grid md:grid-cols-2 lg:grid-cols-[56%_1fr] lg:min-h-[85vh]">
    <div class="tilt-card group relative aspect-[4/3] overflow-hidden [perspective:1200px] md:aspect-auto">
      <Image
        src={piezaDestacada}
        alt="Pieza destacada de NINUMÁ — detalle de elaboración artesanal"
        data-i18n-alt="pieza.imageAlt"
        loading="lazy"
        widths={[400, 640, 900, 1100]}
        sizes="(min-width: 1024px) 56vw, (min-width: 768px) 50vw, 100vw"
        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
      />
    </div>
    <div class="flex flex-col justify-center px-6 py-16 md:px-12 md:py-20 lg:px-16 lg:py-0">
      <span class="text-xs tracking-[0.14em] text-pink uppercase" data-i18n="pieza.eyebrow">Pieza del momento</span>
      <p class="mt-3 text-sm tracking-wide text-white/50">N.º 001</p>
      <h2 class="mt-2 font-display text-[clamp(2.8rem,5vw,5.5rem)] leading-[0.98] tracking-[-0.01em]">
        Nombre<br /><em>de la pieza</em>
      </h2>
      <div class="my-6 h-px w-16 bg-white/15"></div>
      <p class="text-white/70" data-i18n="pieza.materials">Mousse de chocolate negro 72&nbsp;% · Gelatina de violeta · Glaseado espejo a la sangre</p>
      <p class="mt-2 text-sm text-white/50" data-i18n="pieza.inspiration">Inspiración: Drácula — F.F. Coppola, 1992</p>
      <div class="my-6 h-px w-16 bg-white/15"></div>
      <div class="flex items-center gap-4 text-xs tracking-wide text-white/50 uppercase">
        <span data-i18n="pieza.estadoUnica">Pieza única</span>
        <span>2025</span>
      </div>
      <a href="/creaciones/" data-i18n="pieza.cta" class="mt-8 inline-flex items-center gap-2 text-sm tracking-wide text-white/80 hover:text-pink">
        Ver todas las creaciones <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
