---
import EditarPerfilForm from "./EditarPerfilForm.astro";
import FavoritosSection from "./FavoritosSection.astro";
import PlantillasSection from "./PlantillasSection.astro";
import FacturasSection from "./FacturasSection.astro";
---

<section id="dashboard-b2b" class="hidden flex-col gap-12">
  <div class="grid gap-8 md:grid-cols-2">
    <EditarPerfilForm accountType="b2b" />

    <div class="border border-white/10 bg-charcoal p-8 text-sm text-white/60">
      <h2 class="font-display text-xl text-white" data-i18n="cuenta.catalogoConPreciosTitle">Catálogo con precios</h2>
      <p class="mt-4 leading-relaxed" data-i18n="cuenta.catalogoB2bDesc">
        Consulta precios especiales B2B, añade piezas al carrito y confirma el pedido sin salir de tu cuenta.
      </p>
      <div class="mt-4 flex flex-wrap gap-4">
        <a
          href="/cuenta/catalogo/"
          data-i18n="cuenta.verCatalogo"
          class="inline-flex w-fit items-center rounded-full border border-pink px-5 py-2 text-xs tracking-[0.1em] text-pink uppercase transition-colors hover:bg-pink hover:text-black"
        >
          Ver catálogo →
        </a>
        <a
          href="/cuenta/carrito/"
          data-i18n="cuenta.verCarrito"
          class="inline-flex w-fit items-center rounded-full border border-white/15 px-5 py-2 text-xs tracking-[0.1em] text-white/70 uppercase transition-colors hover:border-pink hover:text-pink"
        >
          Ver carrito
        </a>
      </div>
    </div>
  </div>

  <div>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <h2 class="font-display text-xl" data-i18n="cuenta.tusPedidos">Tus pedidos</h2>
      <select
        data-orders-filter
        aria-label="Filtrar pedidos por estado"
        class="border border-white/15 bg-black px-3 py-2 text-xs text-white outline-none focus:border-pink"
      >
        <option value="" data-i18n="cuenta.todosLosEstados">Todos los estados</option>
        <option value="recibido" data-i18n="cuenta.estadoRecibido">Recibido</option>
        <option value="en_obrador" data-i18n="cuenta.estadoEnObrador">En el obrador</option>
        <option value="listo" data-i18n="cuenta.estadoListo">Listo para recoger</option>
        <option value="entregado" data-i18n="cuenta.estadoEntregado">Entregado</option>
      </select>
    </div>
    <p data-orders-empty class="mt-4 hidden text-sm text-white/60" data-i18n="cuenta.pedidosVacioB2b">
      Todavía no tenéis pedidos registrados. Contacta con nosotros desde
      <a href="/contacto/?tipo=b2b" class="text-pink underline underline-offset-2">contacto</a>.
    </p>
    <p data-orders-empty-filtro class="mt-4 hidden text-sm text-white/60" data-i18n="cuenta.pedidosVacioFiltroB2b">No tenéis pedidos con este estado.</p>
    <ul data-orders-list class="mt-4 flex flex-col gap-3"></ul>
  </div>

  <FavoritosSection />

  <PlantillasSection />

  <FacturasSection />
</section>
