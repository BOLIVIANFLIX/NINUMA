  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group fixed right-5 bottom-5 z-[80] flex h-14 w-14 items-center justify-center rounded-full border border-pink/40 bg-charcoal-2 shadow-lg shadow-black/40 transition-transform duration-300 hover:scale-105 hover:border-pink md:right-8 md:bottom-8"
  aria-label="Escribir por WhatsApp"
  data-i18n-aria-label="whatsapp.aria"
>
  <svg viewBox="0 0 24 24" class="h-6 w-6 fill-[#25D366] transition-transform duration-300 group-hover:scale-110" aria-hidden="true">
