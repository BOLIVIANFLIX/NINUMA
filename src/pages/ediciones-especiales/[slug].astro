---
import { Image, getImage } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { getArchivedEditions } from "../../lib/edition";
import { breadcrumbSchema, editionSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const ediciones = await getArchivedEditions();
  return ediciones.map((edicion) => ({
    params: { slug: edicion.slug },
    props: { edicion },
  }));
}

const { edicion } = Astro.props;

const imagenSrc = edicion.imagen ? (await getImage({ src: edicion.imagen, width: 800 })).src : `${new URL("/assets/img/og-image.png", Astro.site)}`;
---

<Layout
  title={`${edicion.nombre} · Edición especial agotada · NINUMÁ`}
  description={edicion.meta}
  path={`/ediciones-especiales/${edicion.slug}/`}
  schema={[
    breadcrumbSchema([
      { name: "Inicio", item: "/" },
      { name: "Ediciones Especiales", item: "/ediciones-especiales/" },
      { name: edicion.nombre, item: `/ediciones-especiales/${edicion.slug}/` },
    ]),
    editionSchema({ nombre: edicion.nombre, descripcion: edicion.descripcion, imagen: imagenSrc, slug: edicion.slug, cajas: edicion.cajas }),
  ]}
>
  <main id="main-content" tabindex="-1">
    <section class="border-b border-white/10 bg-charcoal px-6 pt-20 pb-20 md:px-12 md:pt-40 md:pb-28">
      <div class="mx-auto max-w-[1440px]">
        <nav aria-label="Ruta de navegación" class="mb-10 flex flex-wrap items-center gap-2 text-xs tracking-wide text-white/50 uppercase">
          <a href="/" class="hover:text-pink">Inicio</a>
          <span aria-hidden="true">/</span>
          <a href="/ediciones-especiales/" class="hover:text-pink">Ediciones Especiales</a>
          <span aria-hidden="true">/</span>
          <strong aria-current="page" class="text-white/80">{edicion.nombre}</strong>
        </nav>

        <div class="grid gap-12 md:grid-cols-2 md:gap-20">
          <div class="relative aspect-[3/4] overflow-hidden bg-charcoal-2">
            {edicion.imagen ? (
              <Image src={edicion.imagen} alt={edicion.alt} loading="eager" class="h-full w-full object-cover" />
            ) : (
              <span class="flex h-full w-full items-center justify-center font-display text-6xl font-light text-white/10">?</span>
            )}
          </div>

          <div class="flex flex-col gap-6">
            <div class="flex flex-wrap items-center gap-4">
              <span class="text-xs tracking-[0.14em] text-pink uppercase">Edición especial · {edicion.anio}</span>
              <span class="inline-block border border-white/20 px-5 py-2 text-xs tracking-[0.24em] text-white/60 uppercase" data-i18n="ediciones.estadoAgotada">
                Edición agotada
              </span>
            </div>
            <h1 class="font-display text-[clamp(2.5rem,7vw,6rem)] leading-[0.95] font-light">{edicion.nombre}</h1>
            <p class="max-w-[52ch] text-sm leading-relaxed text-white/60" data-i18n={edicion.metaKey}>{edicion.meta}</p>
            {edicion.descripcion && (
              <p class="max-w-[52ch] text-sm leading-relaxed text-white/60" data-i18n={edicion.descripcionKey}>
                {edicion.descripcion}
              </p>
            )}

            <div class="border-l-2 border-white/20 bg-charcoal-2 p-5">
              <p class="text-xs leading-relaxed text-white/60">
                Esta edición ya no está a la venta — fue una tirada limitada, única e irrepetible. No volverá a hacerse.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {edicion.introDetalle && (
      <section class="border-b border-white/10 bg-black px-6 py-24 md:px-12 md:py-36">
        <div class="mx-auto max-w-[1440px]">
          <p class="max-w-[65ch] text-sm leading-relaxed text-white/60" data-i18n={edicion.introDetalleKey}>
            {edicion.introDetalle}
          </p>
        </div>
      </section>
    )}

    {edicion.especificaciones.length > 0 && (
      <section class="border-b border-white/10 bg-black px-6 pb-24 md:px-12 md:pb-36">
        <div class="mx-auto max-w-[1440px]">
          <dl class="flex flex-col divide-y divide-white/5 border-t border-white/10">
            {edicion.especificaciones.map((s) => (
              <div class="grid grid-cols-[9ch_1fr] gap-6 py-4 text-sm md:grid-cols-[12ch_1fr]">
                <dt class="text-white/50" data-i18n={s.etiquetaKey}>{s.etiqueta}</dt>
                <dd class="text-white" data-i18n={s.valorKey}>{s.valor}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    )}

    {edicion.cajas.length > 0 && (
      <section class="border-b border-white/10 bg-charcoal px-6 py-16 md:px-12">
        <div class="mx-auto max-w-[1440px]">
          <p class="mb-6 text-xs tracking-[0.14em] text-white/50 uppercase">Formatos de esta tirada (precios de referencia, ya no disponibles)</p>
          <ul class="flex flex-wrap gap-4">
            {edicion.cajas.map((c) => (
              <li class="border border-white/10 px-5 py-3 text-sm text-white/60">
                {c.label} — {c.precio.toFixed(2)} €
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <section class="bg-black px-6 py-16 text-center md:px-12">
      <a
        href="/ediciones-especiales/"
        class="inline-flex items-center gap-2 rounded-full border border-pink px-6 py-3 text-xs tracking-[0.1em] text-pink uppercase hover:bg-pink hover:text-black"
      >
        Ver la edición activa →
      </a>
    </section>
  </main>
</Layout>
