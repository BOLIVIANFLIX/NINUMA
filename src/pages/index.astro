---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Manifiesto from "../components/Manifiesto.astro";
import PiezaSpotlight from "../components/PiezaSpotlight.astro";
import Proceso from "../components/Proceso.astro";
import EdicionTeaser from "../components/EdicionTeaser.astro";
import B2BTeaser from "../components/B2BTeaser.astro";
import Contacto from "../components/Contacto.astro";
import { bakerySchema, cafeSchema, breadcrumbSchema } from "../lib/schema";
---

<Layout
  title="NINUMÁ · Pastelería de Autor y Conceptual · Palma de Mallorca"
  description="NINUMÁ — pastelería de autor y conceptual de Ariadna Salvador Ávila en Palma de Mallorca. Cafetería de especialidad y guiones comestibles inspirados en cultura pop, expresionismo y rococó."
  path="/"
  schema={[bakerySchema(), cafeSchema(), breadcrumbSchema([{ name: "Inicio", item: "/" }])]}
>
  <main id="main-content" tabindex="-1">
    <Hero />
    <Manifiesto />
    <PiezaSpotlight />
    <Proceso />
    <EdicionTeaser />
    <B2BTeaser />
    <Contacto />
  </main>
</Layout>
