---
import Layout from "../../layouts/Layout.astro";
import LoginForm from "../../components/cuenta/LoginForm.astro";
---

<Layout
  title="Acceder · Mi cuenta · NINUMÁ"
  description="Accede a tu área privada de cliente NINUMÁ."
  path="/cuenta/login/"
  noindex={true}
  motion={false}
>
  <main id="main-content" tabindex="-1" class="px-6 pt-36 pb-24 md:px-12 md:pt-44">
    <div class="mx-auto max-w-md">
      <h1 class="font-display text-3xl md:text-4xl" data-i18n="cuenta.loginTitle">Acceder</h1>
      <p class="mt-3 text-sm text-white/60" data-i18n="cuenta.loginSubtitle">Entra en tu área de cliente NINUMÁ.</p>
      <div class="mt-10">
        <LoginForm />
      </div>
    </div>
  </main>
</Layout>
