---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Catálogo · Mi cuenta · NINUMÁ"
  description="Catálogo de creaciones NINUMÁ para clientes."
  path="/cuenta/tienda/"
  noindex={true}
  motion={false}
>
  <main id="main-content" tabindex="-1" class="px-6 pt-36 pb-24 md:px-12 md:pt-44">
    <div class="mx-auto max-w-[1440px]">
      <p id="tienda-loading" class="text-sm text-white/60" data-i18n="cuenta.cargandoCatalogo">Cargando catálogo…</p>
      <p id="tienda-error" class="hidden text-sm text-pink-deep" role="alert"></p>

      <div id="tienda-content" class="hidden flex-col gap-8">
        <header class="border-b border-white/10 pb-8">
          <p class="text-xs tracking-[0.14em] text-white/50 uppercase" data-i18n="cuenta.areaClientes">Área de clientes</p>
          <h1 class="mt-1 font-display text-3xl md:text-4xl" data-i18n="cuenta.catalogoTitle">Catálogo</h1>
          <p class="mt-3 text-sm text-white/60" data-i18n="cuenta.tiendaIntro">Pasa el ratón (o toca en móvil) sobre la foto de cada pieza para ver sus ingredientes.</p>
          <div class="mt-4 flex flex-wrap items-center gap-6">
            <a href="/cuenta/" class="text-xs tracking-[0.1em] text-pink uppercase hover:underline" data-i18n="cuenta.volverAMiCuenta">← Volver a mi cuenta</a>
            <a
              href="/cuenta/carrito/"
              class="inline-flex items-center gap-2 rounded-full border border-white/15 px-5 py-2 text-xs tracking-[0.1em] text-white/70 uppercase transition-colors hover:border-pink hover:text-pink"
            >
              <span data-i18n="cuenta.verCarritoSinFlecha">Ver carrito</span> <span id="carrito-count" class="rounded-full bg-pink px-2 py-0.5 text-black">0</span>
            </a>
          </div>
        </header>

        <div role="group" aria-label="Filtrar por categoría" class="flex flex-wrap gap-2">
          <button type="button" class="tienda-filtro-btn rounded-full border border-pink bg-pink px-4 py-1.5 text-xs tracking-[0.08em] text-black uppercase transition-colors" data-filter="all" aria-pressed="true" data-i18n="cuenta.filtroTodo">Todo</button>
          <button type="button" class="tienda-filtro-btn rounded-full border border-white/20 px-4 py-1.5 text-xs tracking-[0.08em] text-white/70 uppercase transition-colors hover:border-pink hover:text-pink" data-filter="tartas" aria-pressed="false" data-i18n="cuenta.filtroTartas">Tartas</button>
          <button type="button" class="tienda-filtro-btn rounded-full border border-white/20 px-4 py-1.5 text-xs tracking-[0.08em] text-white/70 uppercase transition-colors hover:border-pink hover:text-pink" data-filter="bombones" aria-pressed="false" data-i18n="cuenta.filtroBombones">Bombones</button>
          <button type="button" class="tienda-filtro-btn rounded-full border border-white/20 px-4 py-1.5 text-xs tracking-[0.08em] text-white/70 uppercase transition-colors hover:border-pink hover:text-pink" data-filter="postres" aria-pressed="false" data-i18n="cuenta.filtroPostres">Postres</button>
        </div>

        <ul id="tienda-grid" class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3"></ul>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { getSessionProfile } from "../../lib/auth";
  import { getPiezasCatalog } from "../../lib/piezas";
  import { categoriaTienda } from "../../lib/tiendaB2C";
  import { addToCart, getCartCount } from "../../lib/cart";
  import { getMyFavorites, addFavorite, removeFavorite } from "../../lib/favorites";
  import { t } from "../../lib/i18n";

  const loadingEl = document.getElementById("tienda-loading");
  const errorEl = document.getElementById("tienda-error");
  const contentEl = document.getElementById("tienda-content");
  const gridEl = document.getElementById("tienda-grid");
  const carritoCountEl = document.getElementById("carrito-count");
  const esTactil = window.matchMedia("(hover: none), (pointer: coarse)").matches;

  function updateCarritoCount() {
    if (carritoCountEl) carritoCountEl.textContent = String(getCartCount());
  }

  async function init() {
    try {
      const profile = await getSessionProfile();
      if (!profile) {
        window.location.href = "/cuenta/login/";
        return;
      }
      if (profile.account_type === "b2b") {
        window.location.href = "/cuenta/catalogo/";
        return;
      }

      const [piezas, favoritosIniciales] = await Promise.all([getPiezasCatalog(), getMyFavorites()]);
      const favoritos = new Set(favoritosIniciales);

      if (gridEl) {
        for (const pieza of piezas) {
          const categoria = categoriaTienda(pieza.numero);

          const li = document.createElement("li");
          li.dataset.categoria = categoria;
          li.className = "flex flex-col gap-3";

          const perspectiveWrap = document.createElement("div");
          perspectiveWrap.className = "cursor-pointer [perspective:1200px]";
          perspectiveWrap.tabIndex = 0;
          perspectiveWrap.setAttribute("role", "button");
          perspectiveWrap.setAttribute("aria-label", `${t("cuenta.verIngredientesDe", "Ver ingredientes de")} ${pieza.nombre}`);

          const card = document.createElement("div");
          card.className = "relative aspect-[4/5] w-full transition-transform duration-[1600ms] ease-in-out [transform-style:preserve-3d]";

          function girar(activo: boolean) {
            card.style.transform = activo ? "rotateY(180deg)" : "";
          }

          if (esTactil) {
            perspectiveWrap.addEventListener("click", () => {
              girar(card.style.transform !== "rotateY(180deg)");
            });
          } else {
            perspectiveWrap.addEventListener("mouseenter", () => girar(true));
            perspectiveWrap.addEventListener("mouseleave", () => girar(false));
          }
          perspectiveWrap.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              girar(card.style.transform !== "rotateY(180deg)");
            }
          });

          const front = document.createElement("div");
          front.className = "absolute inset-0 overflow-hidden bg-black [backface-visibility:hidden]";
          const img = document.createElement("img");
          img.src = pieza.imagen;
          img.alt = pieza.nombre;
          img.loading = "lazy";
          img.className = "h-full w-full object-cover";
          const overlay = document.createElement("div");
          overlay.className = "absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/90 to-transparent p-5";
          const nombreFront = document.createElement("h2");
          nombreFront.className = "font-display text-xl text-white";
          nombreFront.textContent = pieza.nombre;
          overlay.appendChild(nombreFront);
          front.append(img, overlay);

          const carritoRow = document.createElement("div");
          carritoRow.className = "flex items-center gap-3";

          const favBtn = document.createElement("button");
          favBtn.type = "button";
          favBtn.className = "shrink-0 text-3xl leading-none text-white/70 transition-colors hover:text-pink";
          const favEstaActivo = favoritos.has(pieza.numero);
          favBtn.setAttribute("aria-pressed", String(favEstaActivo));
          favBtn.setAttribute(
            "aria-label",
            favEstaActivo
              ? `${t("cuenta.quitarDeFavoritos", 'Quitar "{n}" de favoritos').replace("{n}", pieza.nombre)}`
              : `${t("cuenta.anadirAFavoritos", 'Añadir "{n}" a favoritos').replace("{n}", pieza.nombre)}`
          );
          favBtn.textContent = favEstaActivo ? "♥" : "♡";
          if (favEstaActivo) favBtn.classList.add("text-pink");
          favBtn.addEventListener("click", async () => {
            const activo = favBtn.getAttribute("aria-pressed") === "true";
            favBtn.disabled = true;
            try {
              if (activo) await removeFavorite(pieza.numero);
              else await addFavorite(pieza.numero);
              favBtn.setAttribute("aria-pressed", String(!activo));
              favBtn.textContent = !activo ? "♥" : "♡";
              favBtn.classList.toggle("text-pink", !activo);
              favBtn.setAttribute(
                "aria-label",
                !activo
                  ? `${t("cuenta.quitarDeFavoritos", 'Quitar "{n}" de favoritos').replace("{n}", pieza.nombre)}`
                  : `${t("cuenta.anadirAFavoritos", 'Añadir "{n}" a favoritos').replace("{n}", pieza.nombre)}`
              );
            } finally {
              favBtn.disabled = false;
            }
          });

          const unidadesSelect = document.createElement("select");
          unidadesSelect.setAttribute("aria-label", `${t("cuenta.unidadesDe", "Unidades de")} ${pieza.nombre}`);
          unidadesSelect.className = "border border-white/20 bg-black/80 px-2 py-1.5 text-xs text-white outline-none focus:border-pink";
          for (let n = 1; n <= 10; n++) {
            const opt = document.createElement("option");
            opt.value = String(n);
            opt.textContent = String(n);
            unidadesSelect.appendChild(opt);
          }
          const addBtn = document.createElement("button");
          addBtn.type = "button";
          addBtn.className =
            "inline-flex items-center rounded-full border border-pink px-4 py-1.5 text-xs tracking-[0.1em] text-pink uppercase transition-colors hover:bg-pink hover:text-black";
          addBtn.textContent = t("cuenta.anadirAlCarrito", "Añadir al carrito");
          addBtn.addEventListener("click", () => {
            addToCart({
              numero: pieza.numero,
              nombre: pieza.nombre,
              precioUnitario: null,
              unidades: Number(unidadesSelect.value),
            });
            updateCarritoCount();
            const original = addBtn.textContent;
            addBtn.textContent = t("cuenta.anadido", "Añadido ✓");
            setTimeout(() => {
              addBtn.textContent = original;
            }, 1200);
          });
          carritoRow.append(favBtn, unidadesSelect, addBtn);

          const back = document.createElement("div");
          back.className =
            "absolute inset-0 flex flex-col justify-center gap-4 border border-white/10 bg-charcoal p-6 [backface-visibility:hidden] [transform:rotateY(180deg)]";
          const nombreBack = document.createElement("h2");
          nombreBack.className = "font-display text-xl text-white";
          nombreBack.textContent = pieza.nombre;
          const lista = document.createElement("ul");
          lista.className = "flex flex-col gap-2 text-sm text-white/70 italic";
          for (const ingrediente of pieza.materiales.split("·").map((s) => s.trim())) {
            const item = document.createElement("li");
            item.textContent = ingrediente;
            lista.appendChild(item);
          }
          back.append(nombreBack, lista);

          card.append(front, back);
          perspectiveWrap.appendChild(card);
          li.append(perspectiveWrap, carritoRow);
          gridEl.appendChild(li);
        }
      }

      const filtroBtns = document.querySelectorAll<HTMLButtonElement>(".tienda-filtro-btn");
      const cards = document.querySelectorAll<HTMLElement>("#tienda-grid > li");
      filtroBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          filtroBtns.forEach((b) => {
            b.classList.remove("border-pink", "bg-pink", "text-black");
            b.classList.add("border-white/20", "text-white/70");
            b.setAttribute("aria-pressed", "false");
          });
          btn.classList.add("border-pink", "bg-pink", "text-black");
          btn.classList.remove("border-white/20", "text-white/70");
          btn.setAttribute("aria-pressed", "true");

          const filter = btn.dataset.filter;
          cards.forEach((card) => {
            const show = filter === "all" || card.dataset.categoria === filter;
            card.classList.toggle("hidden", !show);
          });
        });
      });

      updateCarritoCount();
      loadingEl?.classList.add("hidden");
      contentEl?.classList.remove("hidden");
      contentEl?.classList.add("flex");
    } catch {
      loadingEl?.classList.add("hidden");
      if (errorEl) {
        errorEl.textContent = t("cuenta.errorCargaCatalogo", "No se ha podido cargar el catálogo. Recarga la página o contacta con nosotros.");
        errorEl.classList.remove("hidden");
      }
    }
  }

  init();
</script>
