---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Carrito · Tienda · NINUMÁ"
  description="Tu carrito de la tienda online NINUMÁ. Recogida en el obrador."
  path="/tienda/carrito/"
  motion={false}
>
  <main id="main-content" tabindex="-1" class="px-6 pt-36 pb-24 md:px-12 md:pt-44">
    <div class="mx-auto max-w-[900px]">
      <header class="border-b border-white/10 pb-8">
        <p class="text-xs tracking-[0.14em] text-white/50 uppercase" data-i18n="tienda.eyebrow">Tienda online</p>
        <h1 class="mt-1 font-display text-3xl md:text-4xl" data-i18n="tienda.tuCarrito">Tu carrito</h1>
        <a href="/tienda/" class="mt-4 inline-block text-xs tracking-[0.1em] text-pink uppercase hover:underline" data-i18n="tienda.seguirComprando">
          ← Seguir comprando
        </a>
      </header>

      <p id="carrito-vacio" class="hidden mt-8 text-sm text-white/60" data-i18n="tienda.carritoVacio">
        Tu carrito está vacío. Añade piezas desde la <a href="/tienda/" class="text-pink underline underline-offset-2">tienda</a>.
      </p>

      <div id="carrito-lleno" class="hidden mt-8 flex-col gap-8">
        <ul id="carrito-list" class="flex flex-col gap-3"></ul>

        <div class="flex items-center justify-between border-t border-white/10 pt-6 text-lg">
          <span class="text-white/60" data-i18n="tienda.total">Total</span>
          <span id="carrito-total" class="font-display text-2xl"></span>
        </div>

        <p id="carrito-minimo-aviso" class="hidden text-xs text-pink-deep" role="alert" data-i18n="tienda.minimoAviso">
          El pedido mínimo para pagar online es de 20 €. Añade alguna pieza más para poder pagar.
        </p>

        <button
          type="button"
          id="carrito-pagar"
          data-i18n="tienda.pagarConTarjeta"
          class="inline-flex w-fit items-center rounded-full border border-pink px-6 py-3 text-xs tracking-[0.1em] text-pink uppercase transition-colors hover:bg-pink hover:text-black disabled:cursor-not-allowed disabled:opacity-40"
        >
          Pagar con tarjeta →
        </button>
        <p id="carrito-pagar-error" class="hidden text-xs text-pink-deep" role="alert" aria-live="assertive"></p>
        <p class="text-xs text-white/40" data-i18n="tienda.recogidaNota">Recogida únicamente en el obrador. Sin envíos.</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { getCart, updateCartQuantity, removeFromCart, getCartTotalCents, type CartTiendaItem } from "../../lib/cartTienda";
  import { getSessionProfile } from "../../lib/auth";
  import { t, getCurrentLang } from "../../lib/i18n";

  const MINIMO_CENTS = 2000;

  const vacioEl = document.getElementById("carrito-vacio");
  const llenoEl = document.getElementById("carrito-lleno");
  const listEl = document.getElementById("carrito-list");
  const totalEl = document.getElementById("carrito-total");
  const minimoAvisoEl = document.getElementById("carrito-minimo-aviso");
  const pagarBtn = document.getElementById("carrito-pagar") as HTMLButtonElement | null;
  const pagarErrorEl = document.getElementById("carrito-pagar-error");

  const eur = new Intl.NumberFormat(getCurrentLang(), { style: "currency", currency: "EUR" });

  function renderCart() {
    const items = getCart();
    if (!listEl || !totalEl || !pagarBtn) return;

    vacioEl?.classList.toggle("hidden", items.length > 0);
    llenoEl?.classList.toggle("hidden", items.length === 0);
    llenoEl?.classList.toggle("flex", items.length > 0);
    if (items.length === 0) return;

    listEl.innerHTML = "";
    for (const item of items) {
      const li = document.createElement("li");
      li.className = "flex flex-wrap items-center justify-between gap-4 border border-white/10 px-6 py-4 text-sm";

      const nombre = document.createElement("span");
      nombre.className = "text-white/80";
      nombre.textContent = item.nombre;

      const controls = document.createElement("div");
      controls.className = "flex items-center gap-4";

      const cantidadInput = document.createElement("input");
      cantidadInput.type = "number";
      cantidadInput.min = "1";
      cantidadInput.max = "10";
      cantidadInput.value = String(item.unidades);
      cantidadInput.className = "w-16 border border-white/15 bg-black px-2 py-1 text-sm text-white outline-none focus:border-pink";
      cantidadInput.addEventListener("change", () => {
        const nuevo = Math.max(1, Math.min(10, Number(cantidadInput.value) || 1));
        updateCartQuantity(item.numero, nuevo);
        renderCart();
      });

      const precio = document.createElement("span");
      precio.className = "w-28 text-right text-white/60";
      precio.textContent = eur.format((item.precioUnitarioCents * item.unidades) / 100);

      const quitarBtn = document.createElement("button");
      quitarBtn.type = "button";
      quitarBtn.className = "text-xs tracking-[0.1em] text-white/50 uppercase hover:text-pink";
      quitarBtn.textContent = t("tienda.quitar", "Quitar");
      quitarBtn.addEventListener("click", () => {
        removeFromCart(item.numero);
        renderCart();
      });

      controls.append(cantidadInput, precio, quitarBtn);
      li.append(nombre, controls);
      listEl.appendChild(li);
    }

    const totalCents = getCartTotalCents();
    totalEl.textContent = eur.format(totalCents / 100);

    const cumpleMinimo = totalCents >= MINIMO_CENTS;
    minimoAvisoEl?.classList.toggle("hidden", cumpleMinimo);
    pagarBtn.disabled = !cumpleMinimo;
  }

  pagarBtn?.addEventListener("click", async () => {
    if (!pagarBtn) return;
    const items = getCart();
    if (items.length === 0) return;

    pagarBtn.disabled = true;
    pagarBtn.textContent = t("tienda.redirigiendo", "Redirigiendo a pago…");
    pagarErrorEl?.classList.add("hidden");

    try {
      const profile = await getSessionProfile().catch(() => null);
      const lineas = items.map((i: CartTiendaItem) => ({ tipo: "pieza", numero: i.numero, unidades: i.unidades }));

      const res = await fetch("/api/crear-sesion-pago", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ lineas, userId: profile?.id ?? null, origen: "tienda" }),
      });
      const data = await res.json();
      if (!res.ok || !data.url) throw new Error(data.error || "No se pudo iniciar el pago");
      window.location.href = data.url;
    } catch (err) {
      pagarBtn.disabled = false;
      pagarBtn.textContent = t("tienda.pagarConTarjeta", "Pagar con tarjeta →");
      if (pagarErrorEl) {
        pagarErrorEl.textContent =
          err instanceof Error && err.message ? err.message : t("tienda.pagarError", "No se ha podido iniciar el pago. Inténtalo de nuevo.");
        pagarErrorEl.classList.remove("hidden");
      }
    }
  });

  renderCart();
</script>
